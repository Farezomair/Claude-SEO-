# Copy to .env for local development. In production, set these as Railway
# service variables (never commit real values).

# Secret used to sign the login session cookie. Use a long random string.
SECRET_KEY=change-me-to-a-long-random-string

# Single-owner login credentials.
APP_USERNAME=admin
APP_PASSWORD=change-me

# Database. Leave unset locally to use a SQLite file (seo_agent.db).
# Railway provides this automatically when you attach a Postgres database.
# DATABASE_URL=postgresql://user:password@host:port/dbname
